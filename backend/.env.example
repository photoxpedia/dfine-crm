# Database (Railway provides this automatically when you add PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/zenith_crm?schema=public"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
MAGIC_LINK_EXPIRES_IN="15m"

# App (in production, set APP_URL to your Railway domain e.g. https://your-app.up.railway.app)
APP_URL="http://localhost:5173"
API_URL="http://localhost:3000"
NODE_ENV="development"
PORT=3000

# Email (SendGrid)
SENDGRID_API_KEY="your-sendgrid-api-key"
EMAIL_FROM="noreply@dfinekb.com"
EMAIL_FROM_NAME="D'Fine Kitchen & Bath Remodeling"

# Stripe (SaaS billing)
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Square (client payments)
SQUARE_ACCESS_TOKEN="your-square-access-token"
SQUARE_ENVIRONMENT="sandbox"
SQUARE_LOCATION_ID="your-square-location-id"
SQUARE_WEBHOOK_SIGNATURE_KEY="your-webhook-signature-key"

# S3 (optional - for production file storage)
# When AWS_S3_BUCKET is set, uploads go to S3 instead of local filesystem
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
